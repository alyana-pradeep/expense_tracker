CREATE DATABASE expense_db;
USE expense_db;

CREATE TABLE expenses (
    id INT AUTO_INCREMENT PRIMARY KEY,
    amount INT,
    category VARCHAR(50),
    date DATE
);

CREATE TABLE limits_table (
    id INT PRIMARY KEY,
    daily_limit INT,
    monthly_limit INT,
    yearly_limit INT
);

